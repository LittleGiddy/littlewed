generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  name      String
  role      String   @default("CLIENT") // "SUPER_ADMIN", "CLIENT", "STAFF"
  tenantId  String?
  tenant    Tenant?  @relation(fields: [tenantId], references: [id])
  createdAt DateTime @default(now())
  phone          String?   // optional, for admin use
  emailVerified  DateTime? // null = not verified
  isActive      Boolean  @default(false) // 🔒 new field
  notifications Notification[]
}

model VerificationToken {
  id         String   @id @default(cuid())
  email      String
  otp        String   // 6-digit code
  expiresAt  DateTime
  createdAt  DateTime @default(now())
}

model Tenant {
  id                 String   @id @default(cuid())
  name               String
  subdomain          String   @unique
  plan               String   @default("BASIC")
  status             String   @default("ACTIVE")
  subscriptionStatus String   @default("inactive") // "active" | "inactive" | "cancelled"
  maxGuests          Int      @default(200)
  createdAt          DateTime @default(now())
  credits            Int      @default(0)          // unified credit balance
  transactions       Transaction[]
  simpleEventMode    Boolean  @default(false)
  bypassPayment Boolean @default(false)  // admin bypass for free events

  // Invitation template fields (tenant‑level – optional, can be overridden per event)
  templateCardUrl    String?
  qrPlacementX       Float?
  qrPlacementY       Float?
  qrSize             Int?
  testMode Boolean @default(false)

  users              User[]
  events             Event[]
  pendingEvents      PendingEvent[]
}

model Event {
  id              String   @id @default(cuid())
  name            String
  date            DateTime
  venue           String
  address         String
  total_budget    Int?
  commission_paid Boolean  @default(false)
  tenantId        String
  tenant          Tenant   @relation(fields: [tenantId], references: [id])
  guests          Guest[]
  createdAt       DateTime @default(now())
  // Per‑event invitation card (overrides tenant‑level if present)
  templateCardUrl String?
  qrPlacementX    Float?
  qrPlacementY    Float?
  qrSize          Int?
  includeName         Boolean? @default(false)
  namePlacementX      Float?
  namePlacementY      Float?
  nameFontSize        Int?
  nameFontColor       String? @default("#000000")
  customMessage   String?   // custom invitation message (optional)
  qrColor         String?  @default("#000000")
  qrDotStyle      String?  @default("square") // square, circle, rounded
  guestCount   Int?    // number of guests entered by organiser
}

model PendingEvent {
  id           String   @id @default(cuid())
  name         String
  date         DateTime
  venue        String
  address      String
  total_budget Int
  commission   Int
  tenantId     String
  tenant       Tenant   @relation(fields: [tenantId], references: [id])
  createdAt    DateTime @default(now())
  expiresAt    DateTime
  guestCount   Int?    // optional, for reporting
}

model Guest {
  id             String    @id @default(cuid())
  name           String
  email          String?
  phone          String?
  onWhatsApp     Boolean   @default(false)  @map("on_whatsapp")
  attending      String    @default("pending")
  checkedIn      Boolean   @default(false)
  checkedInAt    DateTime?
  smsCode        String?   @unique
  invitationCard String?
  qrToken        String?
  routingChannel String    @default("sms") @map("routing_channel")
  eventId        String
  event          Event     @relation(fields: [eventId], references: [id])
  createdAt      DateTime  @default(now())
}

model UsageRecord {
  id        String   @id @default(cuid())
  tenantId  String
  eventId   String?
  channel   String   // "whatsapp" or "sms"
  cost      Int      // in same unit as credits
  createdAt DateTime @default(now())
}

model Transaction {
  id              String   @id @default(cuid())
  amount          Int
  type            String   // "CREDIT_PURCHASE" or "COMMISSION_PAYMENT"
  status          String   // "PENDING", "COMPLETED", "FAILED"
  stripeSessionId String?
  tenantId        String
  eventId         String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  userId          String?  // ✅ new: who initiated the transaction

  tenant Tenant @relation(fields: [tenantId], references: [id])
}

// prisma/schema.prisma

model PasswordResetToken {
  id        String   @id @default(cuid())
  email     String
  otp       String
  expiresAt DateTime
  createdAt DateTime @default(now())
}


// prisma/schema.prisma

model Notification {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  title     String
  message   String?
  type      String   // "info", "warning", "success", "alert"
  isRead    Boolean  @default(false)
  link      String?  // optional URL to navigate to
  createdAt DateTime @default(now())
}